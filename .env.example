# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Databricks
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi...

# Oracle Credentials (stored in AWS Secrets Manager, not in .env)
# Retrieve credentials at runtime using boto3 Secrets Manager client:
#
# Example retrieval:
#   import boto3
#   import json
#   client = boto3.client('secretsmanager', region_name=os.getenv('AWS_REGION'))
#   secret = client.get_secret_value(SecretId='negarabank/oracle/credentials')
#   creds = json.loads(secret['SecretString'])
#   ORACLE_USER = creds['username']
#   ORACLE_PASSWORD = creds['password']
#
# Expected secret format in AWS Secrets Manager:
#   {
#     "username": "negarabank_user",
#     "password": "encrypted_password_here",
#     "host": "oracle.example.com",
#     "port": 1521,
#     "database": "NEGARADB"
#   }

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka1:9092,kafka2:9092,kafka3:9092
KAFKA_TOPIC_MOBILE_EVENTS=mobile_clickstream

# S3 Paths
S3_BUCKET_BRONZE=negarabank-bronze
S3_BUCKET_SILVER=negarabank-silver
S3_BUCKET_GOLD=negarabank-gold
S3_BUCKET_CHECKPOINTS=negarabank-checkpoints
